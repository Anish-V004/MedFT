# Gemini API Keys for LLM extraction
# You can provide a single key, or a comma/semicolon separated list for rotation to avoid rate limits
GEMINI_API_KEYS="your_gemini_api_key_1,your_gemini_api_key_2"

# Alternatively, you can use numbered keys:
# GEMINI_API_KEY_1="your_gemini_api_key_1"
# GEMINI_API_KEY_2="your_gemini_api_key_2"

# Optional: openFDA API Key to avoid rate limits during data fetching
OPENFDA_API_KEY="your_openfda_api_key"
